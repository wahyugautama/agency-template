---
import type { Project } from '../data/projects';
interface Props { project: Project; priority?: boolean; }
const { project, priority = false } = Astro.props;
---
<article class="project-card">
  <a href={`/work/${project.slug}`} aria-label={`View ${project.title} project`}>
    <div class="project-image"><img src={project.coverImage.src} alt={project.coverImage.alt} loading={priority ? 'eager' : 'lazy'} /></div>
    <div class="project-meta"><div><h3>{project.title}</h3><p>{project.client}</p></div><p>{project.category} · {project.year}</p></div>
  </a>
</article>
