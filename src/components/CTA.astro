---
interface Props { eyebrow?: string; title?: string; href?: string; label?: string; }
const { eyebrow = 'Start a project', title = 'Have something in mind?', href = '/contact', label = 'Let’s talk' } = Astro.props;
---
<section class="cta-block"><p class="eyebrow">{eyebrow}</p><h2>{title}</h2><a class="circle-link" href={href}>{label}<span aria-hidden="true">↗</span></a></section>
