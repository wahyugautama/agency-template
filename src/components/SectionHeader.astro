---
interface Props { eyebrow?: string; title: string; linkHref?: string; linkLabel?: string; }
const { eyebrow, title, linkHref, linkLabel } = Astro.props;
---
<div class="section-header">
  <div>{eyebrow && <p class="eyebrow">{eyebrow}</p>}<h2>{title}</h2></div>
  {linkHref && <a class="text-link" href={linkHref}>{linkLabel}<span aria-hidden="true">↗</span></a>}
</div>
