---
import BaseLayout from '../layouts/BaseLayout.astro'; import HeroSection from '../components/HeroSection.astro'; import CTAButton from '../components/CTAButton.astro'; import { siteConfig } from '../config/site';
const interest = Astro.url.searchParams.get('interest');
---
<BaseLayout title="Contact & Arrival — Campbell House Penang" description="Contact Campbell House and plan your arrival in George Town, Penang.">
  <HeroSection eyebrow="Contact & arrival" title="Find us in the heart of George Town" copy="Campbell House is located in George Town, Penang, surrounded by heritage streets, cafés, dining, and cultural landmarks." />
  <section class="contact-cards page-shell section-pad">
    <article><p class="eyebrow">Address</p><h2>Campbell House</h2>{siteConfig.address ? <p>{siteConfig.address}</p> : <p>Full verified street address coming soon.</p>}</article>
    <article><p class="eyebrow">Reservations</p><h2>Plan a stay</h2>{siteConfig.phone && <a href={`tel:${siteConfig.phone}`}>{siteConfig.phone}</a>}{siteConfig.email ? <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a> : <p>Verified phone and email details coming soon.</p>}<CTAButton href={siteConfig.bookingUrl} label="Check Availability" variant="text" /></article>
    <article><p class="eyebrow">WhatsApp</p><h2>Message the team</h2>{siteConfig.whatsapp ? <CTAButton href={siteConfig.whatsapp} label="Open WhatsApp" variant="text" /> : <p>A verified WhatsApp contact has not been supplied.</p>}</article>
  </section>
  <section class="arrival page-shell section-pad"><div class="section-intro"><p class="eyebrow">Before you arrive</p><h2>Practical details, clearly explained</h2></div><div class="feature-list"><article><h3>Getting here</h3><p>TODO: Add verified airport, taxi, and public transport guidance.</p></article><article><h3>Parking</h3><p>TODO: Add verified parking availability and instructions.</p></article><article><h3>Check-in</h3><p>TODO: Add verified check-in times and arrival guidance.</p></article><article><h3>Nearby landmarks</h3><p>TODO: Add verified walking times to useful landmarks.</p></article></div></section>
  <section class="enquiry page-shell section-pad"><div><p class="eyebrow">Send an enquiry</p><h2>{interest === 'restaurant' ? 'Plan a table at IL BÁCARO' : 'How can we help with your stay?'}</h2><p>The form is ready for connection to the hotel’s preferred enquiry service.</p></div><form><label>Name<input type="text" name="name" autocomplete="name" /></label><label>Email<input type="email" name="email" autocomplete="email" /></label><label>Message<textarea name="message" rows="5"></textarea></label><button type="button" disabled>Send enquiry</button><small>TODO: Connect and test the form endpoint before enabling submission.</small></form></section>
</BaseLayout>

