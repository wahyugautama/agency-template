---
import BaseLayout from '../layouts/BaseLayout.astro'; import HeroSection from '../components/HeroSection.astro'; import SectionIntro from '../components/SectionIntro.astro'; import CTAButton from '../components/CTAButton.astro'; import FinalCTA from '../components/FinalCTA.astro'; import { siteConfig } from '../config/site'; import { imagery } from '../data/hotel';
---
<BaseLayout title="IL BÁCARO — Italian Restaurant at Campbell House" description="Discover intimate Italian dining at IL BÁCARO, Campbell House Penang.">
  <HeroSection eyebrow="IL BÁCARO · Campbell House" title="Italian dining at Campbell House" copy="A warm, intimate restaurant shaped by thoughtful Italian cooking, easy conversation, and the character of its boutique setting." image={imagery.dining} imageAlt="Intimate restaurant dining room" primary={{ href: siteConfig.restaurantReservationUrl, label: 'Reserve a Table' }} />
  <section class="narrow-section page-shell section-pad"><SectionIntro eyebrow="The restaurant" title="Food-led hospitality, from the kitchen to the room" copy="IL BÁCARO is part of the life of Campbell House: a place for hotel guests and George Town diners to settle in, share a meal, and enjoy Italian cooking in an intimate heritage setting." /></section>
  <section class="feature-list page-shell section-pad"><article><span>01</span><h3>Italian cuisine</h3><p>A focused Italian dining experience at the heart of the house.</p></article><article><span>02</span><h3>Intimate setting</h3><p>Warm, characterful surroundings suited to relaxed meals.</p></article><article><span>03</span><h3>Open to George Town</h3><p>For staying guests, local diners, and visitors to the city.</p></article></section>
  <section class="menus page-shell section-pad"><SectionIntro eyebrow="Menus" title="See what is being served" copy="Current menu links have not yet been supplied." /><div class="button-row disabled-links"><span>Food Menu</span><span>Wine Menu</span><span>Dessert Menu</span><span>Drinks Menu</span></div><!-- TODO: Link only verified current menus or PDFs. --></section>
  <section class="cross-sell page-shell section-pad"><p class="eyebrow">Stay for longer</p><h2>Staying at Campbell House places IL BÁCARO just downstairs.</h2><CTAButton href="/rooms" label="Explore Rooms" /></section>
  <FinalCTA title="Join us at IL BÁCARO" copy="Plan an intimate Italian meal at Campbell House." label="Reserve a Table" href={siteConfig.restaurantReservationUrl} />
</BaseLayout>
